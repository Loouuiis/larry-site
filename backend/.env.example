NODE_ENV=development
PORT=8080
LOG_LEVEL=info

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/larry

JWT_ACCESS_SECRET=replace_with_32_chars_minimum_secret
JWT_REFRESH_SECRET=replace_with_32_chars_minimum_secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

AWS_REGION=eu-west-1
SQS_EVENTS_QUEUE_URL=
SQS_DLQ_URL=

CORS_ORIGINS=http://localhost:3000
REQUIRE_TENANT_HEADER=false
