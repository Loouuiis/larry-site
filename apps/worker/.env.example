NODE_ENV=development
LOG_LEVEL=info

# Must match apps/api/.env DATABASE_URL exactly — if they differ, extracted actions
# will be written to a different database and will not appear in the UI.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/larry
REDIS_URL=redis://localhost:6379

WORKER_CONCURRENCY=5

# AI provider — set to openai, anthropic, or gemini (default: openai)
# Only the key for the active provider is required; others can be left blank.
# If unset, the worker falls back to apps/api/.env for all AI config.
MODEL_PROVIDER=openai

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Email delivery for escalation notifications (optional)
# Get a key at https://resend.com — free tier sends 100 emails/day
# Verified domain: larry-site.com
RESEND_API_KEY=
RESEND_FROM_NOREPLY=Larry <noreply@larry-site.com>
RESEND_FROM_LARRY=Larry <larry@larry-site.com>
