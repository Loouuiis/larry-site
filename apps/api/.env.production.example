NODE_ENV=production
LOG_LEVEL=info

# ── Database & Queue ─────────────────────────────────────────
# Railway: add a Postgres plugin and a Redis plugin — Railway injects these automatically
DATABASE_URL=postgresql://...
REDIS_URL=redis://...

# ── Auth ─────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=<64-char hex>
JWT_REFRESH_SECRET=<64-char hex>
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# ── CORS ─────────────────────────────────────────────────────
# Set to your Vercel frontend URL (no trailing slash)
CORS_ORIGINS=https://your-app.vercel.app

# ── OpenAI ───────────────────────────────────────────────────
# Use demo-specific credentials, NOT dev keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Slack connector ──────────────────────────────────────────
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=https://your-api.up.railway.app/v1/connectors/slack/callback
SLACK_SIGNING_SECRET=

# ── Google Calendar connector ────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-api.up.railway.app/v1/connectors/google-calendar/callback
GOOGLE_CALENDAR_WEBHOOK_URL=https://your-api.up.railway.app/v1/connectors/google-calendar/webhook

# ── Email connector ──────────────────────────────────────────
EMAIL_CONNECTOR_PROVIDER=mock
EMAIL_CONNECTOR_PUBLIC_BASE_URL=https://your-api.up.railway.app

REQUIRE_TENANT_HEADER=false
