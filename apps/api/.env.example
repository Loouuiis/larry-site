NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# Stage 1 target: Neon Postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/larry
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=6I7Pfuh21MxiEtGgMeY3SRJ1dbncQonD
JWT_REFRESH_SECRET=liFGHhrgMGmLBQit2TnTkoumWAMwIJ56
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Slack connector (Stage 1)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:8080/v1/connectors/slack/callback
SLACK_SIGNING_SECRET=
SLACK_BOT_SCOPES=channels:read,channels:history,groups:history,im:history,mpim:history,chat:write
SLACK_SIGNATURE_TOLERANCE_SECONDS=300
SLACK_OAUTH_STATE_TTL_SECONDS=3600

# Google Calendar connector (Stage 1)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/v1/connectors/google-calendar/callback
GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar.readonly
GOOGLE_OAUTH_STATE_TTL_SECONDS=3600
# Optional override; defaults to <GOOGLE_REDIRECT_URI origin>/v1/connectors/google-calendar/webhook
GOOGLE_CALENDAR_WEBHOOK_URL=

# Email connector (Stage 1 mock/bridge)
EMAIL_CONNECTOR_PROVIDER=mock
# Optional; when unset uses inbound request host/protocol for callback URLs
EMAIL_CONNECTOR_PUBLIC_BASE_URL=http://localhost:8080
EMAIL_CONNECTOR_OAUTH_STATE_TTL_SECONDS=3600

CORS_ORIGINS=http://localhost:3000
REQUIRE_TENANT_HEADER=false
