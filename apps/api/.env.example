NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# Stage 1 target: Neon Postgres
DATABASE_URL=
REDIS_URL=

JWT_ACCESS_SECRET=<generate-with-node -e "require('crypto').randomBytes(16).toString('hex')">
# JWT_REFRESH_SECRET is defined here for documentation purposes but is NOT used at runtime.
# Refresh tokens are stored as SHA256 hashes in the refresh_tokens table — they are not signed JWTs.
# See apps/api/src/lib/auth.ts -> issueRefreshToken / hashToken for the implementation.
JWT_REFRESH_SECRET=<generate-with-node -e "require('crypto').randomBytes(16).toString('hex')">
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# AI provider — set to openai, anthropic, or gemini (default: openai)
# Only the key for the active provider is required; others can be left blank.
MODEL_PROVIDER=openai

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Slack connector (Stage 1)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:8080/v1/connectors/slack/callback
SLACK_SIGNING_SECRET=
SLACK_BOT_SCOPES=channels:read,channels:history,groups:history,im:history,mpim:history,chat:write,users:read.email,im:write
SLACK_SIGNATURE_TOLERANCE_SECONDS=300
SLACK_OAUTH_STATE_TTL_SECONDS=3600

# Google Calendar connector (Stage 1)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/v1/connectors/google-calendar/callback
GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar.readonly
GOOGLE_OAUTH_STATE_TTL_SECONDS=3600
# Optional override; defaults to <GOOGLE_REDIRECT_URI origin>/v1/connectors/google-calendar/webhook
GOOGLE_CALENDAR_WEBHOOK_URL=

# Google OAuth sign-in (auth)
GOOGLE_AUTH_REDIRECT_URI=http://localhost:8080/v1/auth/google/callback

# Email connector (Stage 1 mock/bridge)
EMAIL_CONNECTOR_PROVIDER=mock
# Optional; when unset uses inbound request host/protocol for callback URLs
EMAIL_CONNECTOR_PUBLIC_BASE_URL=http://localhost:8080
EMAIL_CONNECTOR_OAUTH_STATE_TTL_SECONDS=3600

CORS_ORIGINS=http://localhost:3000
REQUIRE_TENANT_HEADER=false

# Email sending (Resend) — verified domain: larry-pm.com
RESEND_API_KEY=
RESEND_FROM_NOREPLY=Larry <noreply@larry-pm.com>
RESEND_FROM_LARRY=Larry <larry@larry-pm.com>
FRONTEND_URL=http://localhost:3000
