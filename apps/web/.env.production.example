NODE_ENV=production
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app

# ── API bridge ───────────────────────────────────────────────
# Point to your Railway API service URL
LARRY_API_BASE_URL=https://your-api.up.railway.app

# ── Tenant auto-login (demo) ─────────────────────────────────
LARRY_API_TENANT_ID=11111111-1111-4111-8111-111111111111
LARRY_API_EMAIL=sarah@larry.local
LARRY_API_PASSWORD=<demo password from seed>

# ── Session ──────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=<64-char hex>

# ── Dev bypass — must be false/unset in production ───────────
# NODE_ENV=production already disables this automatically
ALLOW_DEV_AUTH_BYPASS=false
