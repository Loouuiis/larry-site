SESSION_SECRET=
ADMIN_SECRET=

# Shared with API — used to verify Google OAuth one-time codes
JWT_ACCESS_SECRET=

# Email sending (Resend) — verified domain: larry-pm.com
RESEND_API_KEY=
RESEND_FROM_NOREPLY=Larry <noreply@larry-pm.com>
RESEND_FROM_LARRY=Larry <larry@larry-pm.com>

NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Redis — used for login rate limiting across all function instances.
# Set to the same REDIS_URL as the API service.
# Without this, rate limiting falls back to in-memory (not enforced across concurrent Vercel invocations).
REDIS_URL=redis://localhost:6379

# Stage 1 workspace bridge (web -> api)
LARRY_API_BASE_URL=http://localhost:8080
LARRY_API_TENANT_ID=
LARRY_API_EMAIL=
LARRY_API_PASSWORD=
LARRY_AUTO_AI_TRIAGE_ON_TASK_CREATE=true

# Dev auth helpers (local only — never set these in production)
NEXT_PUBLIC_SHOW_DEV_LOGIN=true
DEV_BYPASS_USER_ID=00000000-0000-4000-8000-000000000001
